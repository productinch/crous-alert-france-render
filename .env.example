# Never commit the real token. Copy this file to .env on the server.
TELEGRAM_BOT_TOKEN=put_your_real_token_here_locally
TELEGRAM_TRIAL_CHAT_ID=-1004420745494
TELEGRAM_PREMIUM_CHAT_ID=-1004417792221

CROUS_BASE_URL=https://trouverunlogement.lescrous.fr
CROUS_TOOL_ID=47
CROUS_TOOL_MECHANISM=residual
CROUS_USER_AGENT=CROUSAlertFrance/0.1 (independent student project; contact: your-email@example.com)

# Safe launch value. Set true only for a private technical image test.
ENABLE_IMAGES=false
TELEGRAM_PROTECT_CONTENT=true
PUBLISH_EXISTING_ON_FIRST_RUN=false

POLL_INTERVAL_SECONDS=120
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=4
DATABASE_PATH=data/offers.sqlite3
# Render only: paste the Neon pooled PostgreSQL connection string in its dashboard.
DATABASE_URL=
LOG_PATH=logs/crous-alert.log
