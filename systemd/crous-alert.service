[Unit]
Description=CROUS Alert France
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=crous-alert
Group=crous-alert
WorkingDirectory=/opt/crous-alert
EnvironmentFile=/opt/crous-alert/.env
ExecStart=/opt/crous-alert/.venv/bin/python -m app.main
Restart=on-failure
RestartSec=15
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/crous-alert/data /opt/crous-alert/logs

[Install]
WantedBy=multi-user.target
